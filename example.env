# Postgres
POSTGRES_DB=todo
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# Redis — only required for prod (dev runs without a password)
REDIS_PASSWORD=changeme

# JWT signing secret — REQUIRED in prod. The API refuses to boot without it.
# Generate a fresh random value, e.g.  openssl rand -base64 48
# Must be at least 32 bytes. Never reuse the dev placeholder here.
JWT_SECRET=changeme-generate-a-long-random-secret

# HTTP Basic auth for the Swagger UI (/swagger) and Hangfire dashboard
# (/hangfire) in prod. These are gated because they expose the full API
# surface and background-job internals.
DASHBOARD_USER=admin
DASHBOARD_PASSWORD=changeme

# Production seed — consumed by `dotnet api.dll --seed` via ProdSeeder.
# Forwarded to the api container as Seed__Admin{N}* (see docker-compose.prod.yml).
# One full set per admin; bump ProdSeeder.AdminCount and add another block to
# provision more.
SEED_ADMIN1_NAME=Admin One
SEED_ADMIN1_INITIALS=A1
SEED_ADMIN1_COLOR=#c97a3c
SEED_ADMIN1_EMAIL=admin1@example.com
SEED_ADMIN1_PASSWORD=changeme

SEED_ADMIN2_NAME=Admin Two
SEED_ADMIN2_INITIALS=A2
SEED_ADMIN2_COLOR=#7C3AED
SEED_ADMIN2_EMAIL=admin2@example.com
SEED_ADMIN2_PASSWORD=changeme
